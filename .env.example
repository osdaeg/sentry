# ── Sentry Configuration ──────────────────────────────────────────────────────

# URL base de tu instancia Gotify (sin trailing slash)
GOTIFY_URL=http://192.168.88.100:8088

# Token de cliente Gotify (crear en Settings > Clients)
GOTIFY_TOKEN=TokenDeClidnteAca

# Imagen de fondo (URL absoluta o ruta relativa a /static)
# Dejar vacío para fondo sólido
BACKGROUND_IMAGE=/fondo.png

# Opacidad del fondo de las notificaciones (0.0 a 1.0)
NOTIFICATION_OPACITY=0.70

# Tiempo en segundos que una notificación de prioridad 10 permanece fijada arriba
PRIORITY10_DURATION=30

# Servicios a monitorear en la barra inferior
# Formato: "Nombre|URL", separados por coma
# Ejemplos:
SERVICES=qBittorrent|http://192.168.88.100:8081,Gluetun|http://192.168.88.100:8910/v1/openvpn/status,rclone|http://192.168.88.100:5670
# SERVICES=
